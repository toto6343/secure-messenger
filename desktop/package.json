{
  "name": "secure-messenger-desktop",
  "version": "1.0.0",
  "description": "Secure Messenger Desktop App with E2E Encryption",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": [
    "messenger",
    "encryption",
    "electron",
    "desktop"
  ],
  "author": "김우혁",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.4.0",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.4.0"
  },
  "build": {
    "appId": "com.securemessenger.desktop",
    "productName": "Secure Messenger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  }
}
